# Booking-service env vars. Copy to .env to override compose defaults.

# HTTP listener
PORT=8080
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=5s

# PostgreSQL — required
DATABASE_URL=postgres://booking:booking@postgres:5432/booking?sslmode=disable

# RabbitMQ event bus — opt-in
EVENTS_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=booking.events

# JWT — required. Must match auth-service's signing secret in production.
# This compose value is for local dev only; rotate it for any deployment.
JWT_SECRET=dev-only-secret-replace-me

