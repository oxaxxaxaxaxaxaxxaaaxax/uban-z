# VCS + tooling
.git
.gitignore
.github
.claude
.kilo

# Tests are not needed at runtime
**/*_test.go
test/

# Migrations are applied separately (via goose / sidecar) — not baked into the image
migrations/

# Docs and codegen inputs
docx/

# Build outputs
booking
*.exe

# Editor and OS
.idea
.vscode
.DS_Store

# Environment files (never bake secrets into images)
.env
.env.*
